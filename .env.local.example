# Copy to .env.local and fill in from your Supabase project settings (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
# Service role key — server only, never exposed to the browser. Needed for user invites and cost-stripped agent writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Canonical app origin used to build auth email links. MUST be set in the Vercel
# Production environment to the deployed URL (e.g. https://turk-cure.vercel.app),
# otherwise reset/confirm links inherit the browser origin and can point to
# localhost. Locally, set it to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-domain
